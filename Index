<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Adega O Fluxo | O Fluxo Não Para</title>
    <style>
        :root {
            --gold: #D4AF37;
            --dark: #0a0a0a;
            --gray: #1a1a1a;
            --text: #f5f5f5;
            --green: #25d366;
            --red: #ff3333;
        }
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Arial, sans-serif;
        }
        body {
            background-color: var(--dark);
            color: var(--text);
            padding-bottom: 140px;
        }
        header {
            background: linear-gradient(to bottom, #000, var(--gray));
            padding: 30px 20px;
            text-align: center;
            border-bottom: 2px solid var(--gold);
        }
        header h1 {
            color: var(--gold);
            font-size: 2.2rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 5px;
        }
        header p {
            color: #888;
            font-size: 1rem;
        }
        .container {
            max-width: 600px;
            margin: 0 auto;
            padding: 15px;
        }
        .categoria-title {
            margin: 25px 0 15px;
            color: var(--gold);
            border-left: 4px solid var(--gold);
            padding-left: 10px;
            font-size: 1.3rem;
            text-transform: uppercase;
        }
        .card {
            background: var(--gray);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid #2d2d2d;
        }
        .card-info h3 {
            font-size: 1.05rem;
            margin-bottom: 5px;
            color: #fff;
        }
        .card-info p {
            color: var(--gold);
            font-weight: bold;
            font-size: 1.15rem;
        }
        .btn-add {
            background: var(--gold);
            color: #000;
            border: none;
            padding: 10px 16px;
            border-radius: 6px;
            cursor: pointer;
            font-weight: bold;
            transition: 0.2s;
        }
        .btn-add:active {
            transform: scale(0.95);
        }
        .cart-bar {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: #151515;
            border-top: 2px solid var(--gold);
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 100;
        }
        .cart-info-total {
            color: #fff;
        }
        .cart-info-total span {
            color: var(--gold);
            font-size: 1.3rem;
            font-weight: bold;
            display: block;
        }
        .btn-checkout {
            background: var(--green);
            color: #fff;
            border: none;
            padding: 12px 24px;
            border-radius: 6px;
            font-weight: bold;
            font-size: 1rem;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(37, 211, 102, 0.3);
        }
        /* Modal de Finalização */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.85);
            z-index: 200;
            justify-content: center;
            align-items: center;
            padding: 15px;
        }
        .modal-content {
            background: var(--gray);
            border: 2px solid var(--gold);
            border-radius: 12px;
            width: 100%;
            max-width: 500px;
            padding: 20px;
            max-height: 90vh;
            overflow-y: auto;
        }
        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #333;
            padding-bottom: 10px;
            margin-bottom: 15px;
        }
        .modal-header h2 {
            color: var(--gold);
            font-size: 1.4rem;
        }
        .close-modal {
            color: var(--red);
            font-size: 1.8rem;
            cursor: pointer;
            background: none;
            border: none;
        }
        .form-group {
            margin-bottom: 15px;
        }
        .form-group label {
            display: block;
            margin-bottom: 5px;
            color: #ccc;
            font-size: 0.9rem;
        }
        .form-group input, .form-group select, .form-group textarea {
            width: 100%;
            padding: 10px;
            background: #0d0d0d;
            border: 1px solid #444;
            border-radius: 6px;
            color: #fff;
            font-size: 1rem;
        }
        .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
            border-color: var(--gold);
            outline: none;
        }
        .resumo-itens {
            background: #0d0d0d;
            padding: 10px;
            border-radius: 6px;
            margin-bottom: 15px;
            border: 1px solid #222;
        }
        .resumo-linha {
            display: flex;
            justify-content: space-between;
            font-size: 0.9rem;
            margin-bottom: 5px;
            color: #aaa;
        }
        .btn-enviar-wa {
            width: 100%;
            background: var(--green);
            color: #fff;
            border: none;
            padding: 14px;
            border-radius: 6px;
            font-weight: bold;
            font-size: 1.1rem;
            cursor: pointer;
            margin-top: 10px;
        }
    </style>
</head>
<body>

<header>
    <h1>Adega O Fluxo</h1>
    <p>O FLUXO NÃO PARA • DELIVERY EM TABOÃO DA SERRA</p>
</header>

<div class="container">
    <div id="vitrine"></div>
</div>

<div class="cart-bar" id="cart-bar" style="display: none;">
    <div class="cart-info-total">
        Total do Pedido:
        <span id="cart-total">R$ 0,00</span>
    </div>
    <button class="btn-checkout" onclick="abrirModal()">Fechar Pedido</button>
</div>

<div class="modal" id="modal-checkout">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Dados da Entrega</h2>
            <button class="close-modal" onclick="fecharModal()">&times;</button>
        </div>
        
        <div class="resumo-itens" id="resumo-itens-checkout"></div>

        <div class="form-group">
            <label for="nome-cliente">Seu Nome *</label>
            <input type="text" id="nome-cliente" placeholder="Digite seu nome">
        </div>

        <div class="form-group">
            <label for="endereco-cliente">Endereço Completo (Rua, Número, Bairro) *</label>
            <textarea id="endereco-cliente" rows="3" placeholder="Ex: Rua das Flores, 123 - Parque Pinheiros"></textarea>
        </div>

        <div class="form-group">
            <label for="pagamento-cliente">Forma de Pagamento *</label>
            <select id="pagamento-cliente">
                <option value="PIX">PIX (Mais Rápido)</option>
                <option value="Cartão de Débito">Cartão de Débito (Maquininha)</option>
                <option value="Cartão de Crédito">Cartão de Crédito (Maquininha)</option>
                <option value="Dinheiro">Dinheiro</option>
            </select>
        </div>

        <div class="form-group">
            <label for="obs-cliente">Observação (Opcional)</label>
            <input type="text" id="obs-cliente" placeholder="Ex: Levar troco para R$ 100 ou gelo extra">
        </div>

        <button class="btn-enviar-wa" onclick="finalizarPedido()">Confirmar e Enviar no WhatsApp</button>
    </div>
</div>

<script>
    // Configuração do número oficial da adega
    const whatsappOficial = "5511999999999"; 

    const baseProdutos = [
        { cat: "🔥 Combos da Madrugada", nome: "Combo Patrão (Red Label + 2L Ener + Gelo)", preco: 160.00 },
        { cat: "🔥 Combos da Madrugada", nome: "Combo Cria (White Horse/Ballantines + 2L Ener + Gelo)", preco: 130.00 },
        { cat: "🔥 Combos da Madrugada", nome: "Combo Monstro (Vodka Smirnoff + Ener 2L)", preco: 85.00 },
        { cat: "🔥 Combos da Madrugada", nome: "Combo Gin Premium (Tanqueray + 4 Tônicas)", preco: 190.00 },
        
        { cat: "🍺 Cervejas Trincando", nome: "Heineken Lata 350ml", preco: 8.50 },
        { cat: "🍺 Cervejas Trincando", nome: "Brahma Latão 473ml", preco: 6.00 },
        { cat: "🍺 Cervejas Trincando", nome: "Amstel Latão 473ml", preco: 6.00 },
        { cat: "🍺 Cervejas Trincando", nome: "Skol Lata 350ml", preco: 5.00 },
        { cat: "🍺 Cervejas Trincando", nome: "Itaipava Lata 350ml", preco: 5.00 },
        
        { cat: "🍾 Destilados (Garrafas)", nome: "Whisky Johnnie Walker Red Label 1L", preco: 120.00 },
        { cat: "🍾 Destilados (Garrafas)", nome: "Whisky White Horse 1L", preco: 95.00 },
        { cat: "🍾 Destilados (Garrafas)", nome: "Whisky Ballantine's 1L", preco: 95.00 },
        { cat: "🍾 Destilados (Garrafas)", nome: "Vodka Smirnoff 998ml", preco: 65.00 },
        { cat: "🍾 Destilados (Garrafas)", nome: "Gin Tanqueray 750ml", preco: 150.00 },
        { cat: "🍾 Destilados (Garrafas)", nome: "Gin Rocks 1L", preco: 45.00 },
        
        { cat: "🥤 Refrigerantes & Mixers", nome: "Coca-Cola Original Lata 350ml", preco: 6.50 },
        { cat: "🥤 Refrigerantes & Mixers", nome: "Coca-Cola Zero Lata 350ml", preco: 6.50 },
        { cat: "🥤 Refrigerantes & Mixers", nome: "Guaraná Antarctica Lata 350ml", preco: 5.50 },
        { cat: "🥤 Refrigerantes & Mixers", nome: "Água Tônica Antarctica Lata 350ml", preco: 7.00 },
        { cat: "🥤 Refrigerantes & Mixers", nome: "Energético Monster / Red Bull", preco: 12.00 },
        { cat: "🥤 Refrigerantes & Mixers", nome: "Energético Baly 2L", preco: 18.00 },
        { cat: "🥤 Refrigerantes & Mixers", nome: "Gelo de Coco (Pacote c/ 4)", preco: 8.00 }
    ];

    let carrinho = JSON.parse(localStorage.getItem('carrinho_fluxo')) || [];

    function inicializarVitrine() {
        const vitrine = document.getElementById('vitrine');
        let estruturaHtml = '';
        let categoriaAtual = '';

        baseProdutos.forEach((item, index) => {
            if (item.cat !== categoriaAtual) {
                estruturaHtml += `<h2 class="categoria-title">${item.cat}</h2>`;
                categoriaAtual = item.cat;
            }
            estruturaHtml += `
                <div class="card">
                    <div class="card-info">
                        <h3>${item.nome}</h3>
                        <p>R$ ${item.preco.toFixed(2).replace('.', ',')}</p>
                    </div>
                    <button class="btn-add" onclick="adicionarAoCarrinho(${index})">ADICIONAR</button>
                </div>
            `;
        });
        vitrine.innerHTML = estruturaHtml;
        recalcularTotais();
    }

    function adicionarAoCarrinho(id) {
        carrinho.push(baseProdutos[id]);
        localStorage.setItem('carrinho_fluxo', JSON.stringify(carrinho));
        recalcularTotais();
    }

    function recalcularTotais() {
        const painelCarrinho = document.getElementById('cart-bar');
        const campoTotal = document.getElementById('cart-total');
        
        if (carrinho.length > 0) {
            painelCarrinho.style.display = 'flex';
            const somaTotal = carrinho.reduce((acc, objeto) => acc + objeto.preco, 0);
            campoTotal.innerText = `R$ ${somaTotal.toFixed(2).replace('.', ',')}`;
        } else {
            painelCarrinho.style.display = 'none';
        }
    }

    function abrirModal() {
        if (carrinho.length === 0) return;
        
        const painelResumo = document.getElementById('resumo-itens-checkout');
        let resumoHtml = '';
        
        carrinho.forEach(item => {
            resumoHtml += `
                <div class="resumo-linha">
                    <span>${item.nome}</span>
                    <span>R$ ${item.preco.toFixed(2).replace('.', ',')}</span>
                </div>
            `;
        });
        
        const somaTotal = carrinho.reduce((acc, objeto) => acc + objeto.preco, 0);
        resumoHtml += `
            <div class="resumo-linha" style="border-top: 1px solid #333; padding-top: 5px; margin-top: 5px; font-weight: bold; color: var(--gold);">
                <span>Total dos Produtos:</span>
                <span>R$ ${somaTotal.toFixed(2).replace('.', ',')}</span>
            </div>
        `;
        
        painelResumo.innerHTML = resumoHtml;
        document.getElementById('modal-checkout').style.display = 'flex';
    }

    function fecharModal() {
        document.getElementById('modal-checkout').style.display = 'none';
    }

    function finalizarPedido() {
        const nome = document.getElementById('nome-cliente').value.trim();
        const endereco = document.getElementById('endereco-cliente').value.trim();
        const pagamento = document.getElementById('pagamento-cliente').value;
        const obs = document.getElementById('obs-cliente').value.trim();

        if (!nome || !endereco) {
            alert("Por favor, preencha o seu nome e endereço para a entrega!");
            return;
        }

        let payloadTexto = "*NOVO PEDIDO - ADEGA O FLUXO*\n";
        payloadTexto += "===============================\n\n";
        
        carrinho.forEach(produto => {
            payloadTexto += `• 1x ${produto.nome} - R$ ${produto.preco.toFixed(2).replace('.', ',')}\n`;
        });
        
        const valorFinal = carrinho.reduce((acc, objeto) => acc + objeto.preco, 0);
        payloadTexto += `\n===============================\n`;
        payloadTexto += `*TOTAL: R$ ${valorFinal.toFixed(2).replace('.', ',')}*\n\n`;
        payloadTexto += `*CLIENTE:* ${nome}\n`;
        payloadTexto += `*ENDEREÇO:* ${endereco}\n`;
        payloadTexto += `*FORMA DE PAGAMENTO:* ${pagamento}\n`;
        
        if (obs) {
            payloadTexto += `*OBSERVAÇÃO:* ${obs}\n`;
        }
        
        payloadTexto += `\n_Aguardando confirmação de saída do motoca!_`;

        // Limpa o carrinho local pós-pedido
        carrinho = [];
        localStorage.removeItem('carrinho_fluxo');
        recalcularTotais();
        fecharModal();

        const linkWhatsApp = `https://wa.me/${whatsappOficial}?text=${encodeURIComponent(payloadTexto)}`;
        window.open(linkWhatsApp, '_blank');
    }

    window.onload = inicializarVitrine;
</script>
</body>
</html>
